// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PROCUREMENT
  INVENTORY
}

enum ProcurementType {
  LOCAL
  IMPORTED
  EMERGENCY
  STANDARD
}

enum ListType {
  PROCUREMENT
  PURCHASE
  ACQUIRED
}

enum PartyRole {
  SOURCE
  REQUESTED_BY
  STOCK_OWNER
}

enum ListItemStatus {
  ACTIVE
  REMOVED
  VERIFIED
}

enum MovementAction {
  CREATED
  MOVED_FORWARD
  MOVED_BACKWARD
  REMOVED
}

enum VerificationStatus {
  PENDING
  MATCHED
  PARTIAL
  MISSING
  DAMAGED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String?
  lastName     String?
  role         Role
  refreshToken String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?

  createdLists       WorkflowList[]          @relation("ListCreator")
  removedListItems   ListItem[]              @relation("ListItemRemover")
  productMovements   ProductMovement[]
  verifications      InventoryVerification[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  invitations        Invitation[]            @relation("InvitedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]

  @@map("categories")
}

model Product {
  id              String          @id @default(uuid())
  sku             String          @unique
  name            String
  imageUrl        String?
  categoryId      String
  category        Category        @relation(fields: [categoryId], references: [id])
  procurementType ProcurementType
  productDetails  String?
  description     String?
  unit            String
  createdAt       DateTime        @default(now())

  listItems        ListItem[]
  productMovements ProductMovement[]

  @@index([name])
  @@index([sku])
  @@index([categoryId])
  @@map("products")
}

model WorkflowList {
  id          String   @id @default(uuid())
  name        String
  type        ListType
  createdById String
  createdBy   User     @relation("ListCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  items         ListItem[]
  movementsFrom ProductMovement[] @relation("MovementFromList")
  movementsTo   ProductMovement[] @relation("MovementToList")

  @@index([type, createdAt])
  @@index([createdById])
  @@map("lists")
}

model ListItem {
  id                String         @id @default(uuid())
  listId            String
  list              WorkflowList   @relation(fields: [listId], references: [id])
  productId         String
  product           Product        @relation(fields: [productId], references: [id])
  quantity          Int
  costPrice         Decimal?       @db.Decimal(10, 2)
  regularPrice      Decimal?       @db.Decimal(10, 2)
  salesPrice        Decimal?       @db.Decimal(10, 2)
  minimum20         Decimal?       @db.Decimal(10, 2)
  minimum4          Decimal?       @db.Decimal(10, 2)
  finalSellingPrice Decimal?       @db.Decimal(10, 2)
  status            ListItemStatus @default(ACTIVE)
  parentItemId      String?
  parentItem        ListItem?      @relation("ListItemLineage", fields: [parentItemId], references: [id])
  childItems        ListItem[]     @relation("ListItemLineage")
  removedAt         DateTime?
  removedById       String?
  removedBy         User?          @relation("ListItemRemover", fields: [removedById], references: [id])
  createdAt         DateTime       @default(now())

  parties       ListItemParty[]
  movements     ProductMovement[]
  verifications InventoryVerification[]

  @@index([listId])
  @@index([productId])
  @@index([parentItemId])
  @@index([status])
  @@index([listId, status])
  @@map("list_items")
}

model ListItemParty {
  id         String    @id @default(uuid())
  listItemId String
  listItem   ListItem  @relation(fields: [listItemId], references: [id], onDelete: Cascade)
  name       String
  role       PartyRole
  createdAt  DateTime  @default(now())

  @@index([listItemId])
  @@index([listItemId, role])
  @@map("list_item_parties")
}

model ProductMovement {
  id         String         @id @default(uuid())
  productId  String
  product    Product        @relation(fields: [productId], references: [id])
  fromListId String?
  fromList   WorkflowList?  @relation("MovementFromList", fields: [fromListId], references: [id])
  toListId   String?
  toList     WorkflowList?  @relation("MovementToList", fields: [toListId], references: [id])
  listItemId String?
  listItem   ListItem?      @relation(fields: [listItemId], references: [id])
  action     MovementAction
  movedById  String
  movedBy    User           @relation(fields: [movedById], references: [id])
  createdAt  DateTime       @default(now())

  @@index([productId])
  @@index([fromListId])
  @@index([toListId])
  @@index([movedById])
  @@index([createdAt])
  @@map("product_movements")
}

model InventoryVerification {
  id               String             @id @default(uuid())
  listItemId       String
  listItem         ListItem           @relation(fields: [listItemId], references: [id])
  verifiedById     String
  verifiedBy       User               @relation(fields: [verifiedById], references: [id])
  expectedQuantity Int
  actualQuantity   Int
  status           VerificationStatus @default(PENDING)
  notes            String?
  verifiedAt       DateTime           @default(now())

  @@index([listItemId])
  @@index([verifiedById])
  @@index([status])
  @@map("inventory_verifications")
}

model PricingSetting {
  id String @id @default(uuid())

  investmentFundRate        Decimal @db.Decimal(6, 4)
  operationProfitRate       Decimal @db.Decimal(6, 4)
  netProfitRateOfOP         Decimal @db.Decimal(6, 4)
  payrollRateOfOPMinusNP    Decimal @db.Decimal(6, 4)
  otherCostsRateOfOPMinusNP Decimal @db.Decimal(6, 4)
  salesTaxRate20            Decimal @db.Decimal(6, 4)
  salesTaxRate4             Decimal @db.Decimal(6, 4)

  name     String?
  isActive Boolean @default(true)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
  @@map("pricing_settings")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  actorEmail String
  action     String
  entityType String
  entityId   String
  entitySku  String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType])
  @@index([entityId])
  @@index([entitySku])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

enum NotificationType {
  PROCUREMENT_LIST_CREATED
  ITEM_MOVED_TO_PURCHASE
  PURCHASE_LIST_READY
  ITEM_MOVED_TO_ACQUIRED
  ACQUIRED_LIST_READY
  VERIFICATION_PENDING
  VERIFICATION_MISMATCH
  LIST_ITEM_PRICING_UPDATED
  USER_INVITATION_SENT
  SYSTEM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Invitation {
  id          String           @id @default(uuid())
  email       String
  role        Role
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([email])
  @@index([status])
  @@index([token])
  @@map("invitations")
}
