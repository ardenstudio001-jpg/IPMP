// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  INVENTORY
  PROCUREMENT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String?
  lastName     String?
  role         Role
  refreshToken String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?

  createdProducts  Product[] @relation("ProductCreator")
  approvedProducts Product[] @relation("ProductApprover")
  costedProducts   Product[] @relation("ProductCostingCompleter")

  notifications Notification[]
  auditLogs     AuditLog[]
  invitations   Invitation[] @relation("InvitedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@map("users")
}

model Product {
  id                String        @id @default(uuid())
  name              String
  quantity          Int
  unit              String
  sku               String?       @unique
  unitCostPrice     Decimal?      @db.Decimal(10, 2)
  totalCostPrice    Decimal?      @db.Decimal(10, 2)
  oldSellingPrice   Decimal?      @db.Decimal(10, 2)
  investmentFund    Decimal?      @db.Decimal(10, 2)
  operationProfit   Decimal?      @db.Decimal(10, 2)
  netProfit         Decimal?      @db.Decimal(10, 2)
  payrollFund       Decimal?      @db.Decimal(10, 2)
  otherCosts        Decimal?      @db.Decimal(10, 2)
  grossProfit       Decimal?      @db.Decimal(10, 2)
  priceBeforeTax    Decimal?      @db.Decimal(10, 2)
  minimum4Percent   Decimal?      @db.Decimal(10, 2)
  minimum20Percent  Decimal?      @db.Decimal(10, 2)
  finalSellingPrice Decimal?      @db.Decimal(10, 2)
  printed           Boolean       @default(false)
  status            ProductStatus

  createdById String
  createdBy   User @relation("ProductCreator", fields: [createdById], references: [id])

  approvedById String?
  approvedBy   User? @relation("ProductApprover", fields: [approvedById], references: [id])

  costingCompletedById String?
  costingCompletedBy   User? @relation("ProductCostingCompleter", fields: [costingCompletedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([status])
  @@index([sku])
  @@index([createdAt])
  @@map("products")
}

enum ProductStatus {
  PENDING_COSTING
  COSTING_COMPLETED
  APPROVED
  REJECTED
}

model PricingSetting {
  id String @id @default(uuid())

  investmentFundRate        Decimal @db.Decimal(6, 4)
  operationProfitRate       Decimal @db.Decimal(6, 4)
  netProfitRateOfOP         Decimal @db.Decimal(6, 4)
  payrollRateOfOPMinusNP    Decimal @db.Decimal(6, 4)
  otherCostsRateOfOPMinusNP Decimal @db.Decimal(6, 4)
  salesTaxRate20            Decimal @db.Decimal(6, 4)
  salesTaxRate4             Decimal @db.Decimal(6, 4)

  name     String?
  isActive Boolean @default(true)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
  @@map("pricing_settings")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  actorEmail String
  action     String
  entityType String
  entityId   String
  entitySku  String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType])
  @@index([entityId])
  @@index([entitySku])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

enum NotificationType {
  PRODUCT_CREATED
  COSTING_COMPLETED
  PRODUCT_APPROVED
  SELLING_PRICE_CHANGED
  USER_INVITATION_SENT
  SYSTEM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Invitation {
  id          String           @id @default(uuid())
  email       String
  role        Role
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([email])
  @@index([status])
  @@index([token])
  @@map("invitations")
}
